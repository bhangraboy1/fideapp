class PlayerViewModel: ObservableObject {
    @Published var players: [Player] = []
    @Published var searchResults: [Player] = []
    
    func fetchData() {
        guard let fileURL = Bundle.main.url(forResource: "fide 2", withExtension: "txt") else {
            print("Failed to locate fide.txt in bundle.")
            return
        }
        
        do {
            let data = try Data(contentsOf: fileURL)
            parseFixedWidth(data: data)
        } catch {
            print("Failed to load fide.txt: \(error.localizedDescription)")
        }
    }
    
    func parseFixedWidth(data: Data) {
        if let fileContent = String(data: data, encoding: .utf8) {
            let rows = fileContent.components(separatedBy: "\n")
            var parsedPlayers: [Player] = []
            
            for row in rows.dropFirst() {
                guard row.count >= 48 else { continue } // Ensure row has enough characters
                let fideID = String(row[row.startIndex..<row.index(row.startIndex, offsetBy: 15)].trimmingCharacters(in: .whitespaces))
                let name = String(row[row.index(row.startIndex, offsetBy: 15)..<row.index(row.startIndex, offsetBy: 75)]).trimmingCharacters(in: .whitespaces)
                let federation = String(row[row.index(row.startIndex, offsetBy: 75)..<row.index(row.startIndex, offsetBy: 79)]).trimmingCharacters(in: .whitespaces)
                let gender = String(row[row.index(row.startIndex, offsetBy: 79)..<row.index(row.startIndex, offsetBy: 81)]).trimmingCharacters(in: .whitespaces)
                let title = String(row[row.index(row.startIndex, offsetBy: 83)..<row.index(row.startIndex, offsetBy: 86)]).trimmingCharacters(in: .whitespaces)
                let rating_standard = Int(row[row.index(row.startIndex, offsetBy: 113)..<row.index(row.startIndex, offsetBy: 118)].trimmingCharacters(in: .whitespaces)) ?? 0
                let birthyear = Int(row[row.index(row.startIndex, offsetBy: 126)..<row.index(row.startIndex, offsetBy: 130)].trimmingCharacters(in: .whitespaces)) ?? 0
                
                let rating_rapid = Int(row[row.index(row.startIndex, offsetBy: 35)..<row.index(row.startIndex, offsetBy: 40)].trimmingCharacters(in: .whitespaces)) ?? 0
                let rating_blitz = Int(row[row.index(row.startIndex, offsetBy: 40)..<row.index(row.startIndex, offsetBy: 45)].trimmingCharacters(in: .whitespaces)) ?? 0
                let country = String(row[row.index(row.startIndex, offsetBy: 45)..<row.index(row.startIndex, offsetBy: 48)]).trimmingCharacters(in: .whitespaces)

                
                let player = Player(fideID: fideID, name: name, federation: federation, gender: gender, title: title, rating_standard: rating_standard, rating_rapid: rating_rapid, rating_blitz: rating_blitz, country: country, birthyear: birthyear)
                parsedPlayers.append(player)
            }
            
            DispatchQueue.main.async {
                self.players = parsedPlayers
                self.searchResults = parsedPlayers // Show all players initially
            }
        }
    }
    
    func searchPlayers(query: String) {
        if query.isEmpty {
            searchResults = players
        } else {
            searchResults = players.filter { player in
                player.name.localizedCaseInsensitiveContains(query) ||
                player.federation.localizedCaseInsensitiveContains(query) ||
                "\(player.rating_standard)".contains(query) ||
                "\(player.rating_rapid)".contains(query) ||
                "\(player.rating_blitz)".contains(query)
            }
        }
    }
}

// Defines Class SavedPlayersViewModel
// Functions
//   addPlayer
//   removePlayer
//   sortnumerically
//   sortAlphabetically

class SavedPlayersViewModel: ObservableObject {
    @Published var isSortedDescending: Bool = true
    private var isAlphabeticalAscending = true
    
    @Published var savedPlayers: [Player] = [] {
        didSet {
            saveToUserDefaults()
        }
    }
    
    private let savedPlayersKey = "savedPlayers"

    init() {
        loadFromUserDefaults()
    }

    func addPlayer(_ player: Player) {
        if !savedPlayers.contains(where: { $0.fideID == player.fideID }) {
            savedPlayers.append(player)
        }
    }

    func removePlayer(_ player: Player) {
        savedPlayers.removeAll { $0.fideID == player.fideID }
    }

    private func saveToUserDefaults() {
        if let encoded = try? JSONEncoder().encode(savedPlayers) {
            UserDefaults.standard.set(encoded, forKey: savedPlayersKey)
        }
    }
    func toggleSortOrder() {
        isSortedDescending.toggle()
        savedPlayers.sort { isSortedDescending ? $0.rating_standard > $1.rating_standard : $0.rating_standard < $1.rating_standard }
    }
    func toggleAlphabeticalSort() {
        isAlphabeticalAscending.toggle()
        savedPlayers.sort { isAlphabeticalAscending ? $0.name < $1.name : $0.name > $1.name }
    }
    
    private func loadFromUserDefaults() {
        if let data = UserDefaults.standard.data(forKey: savedPlayersKey),
           let decoded = try? JSONDecoder().decode([Player].self, from: data) {
            savedPlayers = decoded
        }
    }
}


