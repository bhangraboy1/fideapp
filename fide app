struct SavedView: View {
    @EnvironmentObject var savedPlayersViewModel: SavedPlayersViewModel
    @State private var showChart = false
    
    var body: some View {
        NavigationView {
            VStack {
                HStack {
                    Spacer()
                    Button(action: savedPlayersViewModel.toggleAlphabeticalSort) {
                        Image(systemName: "textformat.abc").font(.title2)
                    }
                    .padding()
                    Button(action: savedPlayersViewModel.toggleSortOrder) {
                        Image(systemName: savedPlayersViewModel.isSortedDescending ? "arrow.up" : "arrow.down").font(.title2)
                    }
                    .padding()
                    Button(action: { showChart.toggle() }) {
                        Image(systemName: "chart.line.uptrend.xyaxis").font(.title2)
                    }
                    .padding()
                }
 
                    List {
                        ForEach(savedPlayersViewModel.savedPlayers) { player in
                            NavigationLink(destination: SinglePlayerView(player: player)) {
                                VStack {
                                    HStack {
                                        Text(player.name).font(.headline)
                                        Circle()
                                            .frame(width: 10, height: 10)
                                            .foregroundColor(player.gender == "M" ? .blue : .pink)
                                    }
                                    
                                    Text(player.title.isEmpty ? "" : player.title).font(.subheadline).foregroundColor(.gray)
                                    Text("\(String(player.birthyear)) \(player.federation) \(player.fideID)").font(.system(size: 12))
                                    Text("\(String(player.rating_standard)) \(player.rating_rapid) \(player.rating_blitz)").font(.system(size: 14))
                                    }
                                }
                            }
                        .onDelete { indexSet in
                            indexSet.forEach { index in
                                let player = savedPlayersViewModel.savedPlayers[index]
                                savedPlayersViewModel.removePlayer(player)
                            }
                        }
                    }
                    .listStyle(PlainListStyle())
            }
            .navigationTitle("Peer Ratings")

            .sheet(isPresented: $showChart) {
                RatingsChartView(players: savedPlayersViewModel.savedPlayers)
            }

        }
    }
}

