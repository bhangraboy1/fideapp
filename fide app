// STRUCT Player
struct Player: Identifiable, Codable {
    var id = UUID()
    let fideID: String
    let name: String
    let federation: String
    let gender: String
    let title: String
    let rating_standard: Int
    let rating_rapid: Int
    let rating_blitz: Int
    let country: String
    let birthyear: Int

    init(fideID: String, name: String, federation: String, gender: String, title: String, rating_standard: Int, rating_rapid: Int, rating_blitz: Int, country: String, birthyear: Int) {
        self.fideID = fideID
        self.name = name
        self.federation = federation
        self.gender = gender
        self.title = title
        self.rating_standard = rating_standard
        self.rating_rapid = rating_rapid
        self.rating_blitz = rating_blitz
        self.country = country
        self.birthyear = birthyear
    }
    
    private enum CodingKeys: String, CodingKey {
        case fideID, name, federation, gender, title, rating_standard, rating_rapid, rating_blitz, country, birthyear
    }
    // Custom Decoder to handle UUID separately
    init(from decoder: Decoder) throws {
        let container = try decoder.container(keyedBy: CodingKeys.self)
        fideID = try container.decode(String.self, forKey: .fideID)
        name = try container.decode(String.self, forKey: .name)
        federation = try container.decode(String.self, forKey: .federation)
        gender = try container.decode(String.self, forKey: .gender)
        title = try container.decode(String.self, forKey: .title)
        rating_standard = try container.decode(Int.self, forKey: .rating_standard)
        rating_rapid = try container.decode(Int.self, forKey: .rating_rapid)
        rating_blitz = try container.decode(Int.self, forKey: .rating_blitz)
        country = try container.decode(String.self, forKey: .country)
        birthyear = try container.decode(Int.self, forKey: .birthyear)
    }
}

